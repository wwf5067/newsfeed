# 部署到 Lighthouse 后,复制为 .env(同目录)。**不要提交到 git。**

# === 镜像 ===
# CI 推到 GHCR 后,这里填完整镜像地址。例:ghcr.io/nikogao/newsfeed-api:abc1234
API_IMAGE=ghcr.io/wwf5067/newsfeed-api:latest
CRAWLER_IMAGE=ghcr.io/wwf5067/newsfeed-crawler:latest
EXTRACTOR_IMAGE=ghcr.io/wwf5067/newsfeed-extractor:latest

# === 数据库 ===
# 生产强烈建议改成强密码
POSTGRES_USER=newsfeed
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=newsfeed

# === 知乎爬虫 cookie ===
# 浏览器 F12 复制整段 cookie 头,长字符串单行
ZHIHU_COOKIE=
ZHIHU_SCHEDULE=0 */30 * * * *

# 首次部署时设为 true,可以立刻抓一次确认链路通;之后改回 false 或删掉
RUN_ON_START=false

# 文章保留天数,超过此天数的旧文章自动清理。设为 0 则不清理。
RETENTION_DAYS=30

# === 抽取服务 ===
# 抽取实现: rule(规则,默认) | llm(尚未实现)
EXTRACTOR_BACKEND=rule
# cron 表达式(支持秒位),默认每 5 分钟扫一批
EXTRACTOR_SCHEDULE=0 */5 * * * *
# 每批最多处理多少篇待抽取文章
EXTRACTOR_BATCH_SIZE=50
