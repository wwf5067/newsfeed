# 复制为 .env 并按需修改
APP_ENV=dev
LOG_LEVEL=debug

# PostgreSQL 连接串
# 本地: postgres://newsfeed:newsfeed@localhost:5432/newsfeed?sslmode=disable
# 生产建议为两个服务分配不同账号(crawler 读写, api 只读)
DATABASE_URL=postgres://newsfeed:newsfeed@localhost:5432/newsfeed?sslmode=disable

# API 服务监听地址(对外)
API_ADDR=:8080
API_READ_TIMEOUT=10s
API_WRITE_TIMEOUT=15s

# Crawler 内部 health 端点(仅本机)
CRAWLER_ADDR=127.0.0.1:8081

# === 数据源:知乎热榜 ===
# 浏览器登录知乎后,F12 -> Network -> 任一请求 -> Request Headers -> 复制整段 Cookie 值粘贴到这里
# 不填则该源会跳过(crawler 启动时打印一条 warn,不影响其它源)
ZHIHU_COOKIE=
# cron 表达式,支持秒位。默认 30 分钟一次
ZHIHU_SCHEDULE=0 */30 * * * *

# === 数据源:B 站热门(无需 cookie)===
# 显式开关,避免在某天接口风控时还在频繁打;关闭后该源不注册,不影响其它源
BILIBILI_ENABLED=true
BILIBILI_SCHEDULE=0 */30 * * * *

# 调试用:启动 crawler 时立即抓一次(不等 cron)
RUN_ON_START=false

# 文章保留天数,超过此天数的旧文章自动清理。设为 0 则不清理。
RETENTION_DAYS=90

# === 每日精选邮件(可选)===
# SMTP_HOST 为空时该 job 不注册,crawler 仍正常启动。
# QQ 邮箱授权码: https://service.mail.qq.com/detail/0/75
# 163 邮箱授权码: https://help.mail.163.com/faqDetail.do?code=d7a5dc8471cd0c0e8b4287f7a30148e7
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
DIGEST_TO=
# 邮件正文里拼绝对链接用,部署后改成你的对外域名
SITE_URL=http://localhost:3000
DIGEST_SCHEDULE=0 0 8 * * *
