# 复制为 .env 并按需修改
APP_ENV=dev
LOG_LEVEL=debug

# PostgreSQL 连接串
# 本地: postgres://newsfeed:newsfeed@localhost:5432/newsfeed?sslmode=disable
# 生产建议为两个服务分配不同账号(crawler 读写, api 只读)
DATABASE_URL=postgres://newsfeed:newsfeed@localhost:5432/newsfeed?sslmode=disable

# API 服务监听地址(对外)
API_ADDR=:8080
API_READ_TIMEOUT=10s
API_WRITE_TIMEOUT=15s

# Crawler 内部 health 端点(仅本机)
CRAWLER_ADDR=127.0.0.1:8081

# === 数据源:知乎热榜 ===
# 浏览器登录知乎后,F12 -> Network -> 任一请求 -> Request Headers -> 复制整段 Cookie 值粘贴到这里
# 不填则该源会跳过(crawler 启动时打印一条 warn,不影响其它源)
ZHIHU_COOKIE=
# cron 表达式,支持秒位。默认 30 分钟一次
ZHIHU_SCHEDULE=0 */30 * * * *

# 调试用:启动 crawler 时立即抓一次(不等 cron)
RUN_ON_START=false

# 文章保留天数,超过此天数的旧文章自动清理。设为 0 则不清理。
RETENTION_DAYS=30
